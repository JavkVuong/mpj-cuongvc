pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        TF_DIR = 'terraform/environments/production'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm

                sh '''
                    echo "Branch: ${BRANCH_NAME:-unknown}"
                    git rev-parse --short HEAD
                '''
            }
        }

        stage('Verify Environment') {
            steps {
                sh '''
                    set -eu

                    terraform version
                    aws --version
                    aws sts get-caller-identity
                '''
            }
        }

        stage('Terraform Format') {
            steps {
                sh '''
                    set -eu

                    terraform fmt -check -recursive terraform
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh '''
                        set -eu

                        terraform init \
                          -input=false \
                          -lock-timeout=5m
                    '''
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir("${TF_DIR}") {
                    sh '''
                        set -eu
                        terraform validate
                    '''
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir("${TF_DIR}") {
                    script {
                        int exitCode = sh(
                            script: '''
                                set +e

                                terraform plan \
                                  -input=false \
                                  -lock-timeout=5m \
                                  -detailed-exitcode \
                                  -out=tfplan

                                exit_code=$?

                                if [ "$exit_code" -eq 0 ]; then
                                    terraform show -no-color tfplan > tfplan.txt
                                    exit 0
                                fi

                                if [ "$exit_code" -eq 2 ]; then
                                    terraform show -no-color tfplan > tfplan.txt
                                    exit 2
                                fi

                                exit 1
                            ''',
                            returnStatus: true
                        )

                        if (exitCode == 0) {
                            env.TF_HAS_CHANGES = 'false'
                            echo 'Terraform plan is clean. No infrastructure changes.'
                        } else if (exitCode == 2) {
                            env.TF_HAS_CHANGES = 'true'
                            echo 'Terraform detected infrastructure changes.'
                        } else {
                            error('Terraform plan failed.')
                        }
                    }
                }
            }
        }

        stage('Archive Plan') {
            steps {
                archiveArtifacts(
                    artifacts: "${TF_DIR}/tfplan.txt",
                    fingerprint: true,
                    allowEmptyArchive: false
                )
            }
        }

        stage('Approval') {
            when {
                expression {
                    env.TF_HAS_CHANGES == 'true'
                }
            }

            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    input(
                        message: 'Apply this Terraform plan to production?',
                        ok: 'Apply'
                    )
                }
            }
        }

        stage('Terraform Apply') {
            when {
                expression {
                    env.TF_HAS_CHANGES == 'true'
                }
            }

            steps {
                dir("${TF_DIR}") {
                    sh '''
                        set -eu

                        terraform apply \
                          -input=false \
                          -lock-timeout=5m \
                          tfplan
                    '''
                }
            }
        }

        stage('Final Plan Check') {
            steps {
                dir("${TF_DIR}") {
                    sh '''
                        set -eu

                        terraform plan \
                          -input=false \
                          -lock-timeout=5m \
                          -detailed-exitcode

                        exit_code=$?

                        if [ "$exit_code" -eq 0 ]; then
                            echo "Terraform state matches the configuration."
                            exit 0
                        fi

                        if [ "$exit_code" -eq 2 ]; then
                            echo "Terraform still detects changes after apply."
                            exit 1
                        fi

                        exit "$exit_code"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Terraform pipeline completed successfully.'
        }

        failure {
            echo 'Terraform pipeline failed. Review the failed stage and tfplan.txt.'
        }

        aborted {
            echo 'Terraform apply was not approved or the pipeline was aborted.'
        }

        always {
            sh '''
                rm -f \
                  "${TF_DIR}/tfplan" \
                  "${TF_DIR}/tfplan.txt" || true
            '''
        }
    }
}
